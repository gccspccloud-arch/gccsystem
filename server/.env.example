NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?appName=Cluster0

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins (no trailing slash).
# Dev: http://localhost:5173
# Prod: https://gcc-web.onrender.com  (or multiple: "https://a.com,https://b.com")
CLIENT_URL=http://localhost:5173

SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
